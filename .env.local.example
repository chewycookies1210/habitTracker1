# Supabase (Project Settings -> API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App gate
APP_PASSCODE=choose-a-memorable-passcode

# ntfy.sh
NTFY_TOPIC=your-private-topic-name

# IANA timezone used to resolve "today" and the 9:30pm nudge check
APP_TIMEZONE=America/Guatemala

# Shared secret the external scheduler (GitHub Actions, see
# .github/workflows/notify-cron.yml) sends as "Authorization: Bearer <secret>".
# Set the same value here, in Vercel's env vars, and as the CRON_SECRET repo
# secret in GitHub. Leave unset locally to skip auth on the cron route in dev.
CRON_SECRET=
